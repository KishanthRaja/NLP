import pandas as pd
import nltk
import string

from nltk.corpus import stopwords
from nltk.tokenize import word_tokenize

from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB

from sklearn.metrics import (
    accuracy_score,
    classification_report,
    confusion_matrix
)


nltk.download('punkt')
nltk.download('stopwords')

data = {
    "query": [

        # Ambiguous Queries
        "Apple price",
        "Java course",
        "Python tutorial",
        "Bank account",
        "Jaguar speed",
        "Mercury information",
        "Mouse not working",
        "Corona effects",

        # Complex Queries
        "How can machine learning improve medical diagnosis systems?",
        "Explain blockchain technology in supply chain management",
        "How does artificial intelligence help autonomous vehicles?",
        "Describe climate change impact on agriculture",
        "How to build a deep learning model for image classification?",
        "Explain natural language processing techniques",
        "What are the ethical challenges in AI systems?",
        "How can NLP detect fake news effectively?",

        # Simple Queries
        "What is Python?",
        "Define computer network",
        "What is AI?",
        "Explain operating system",
        "What is machine learning?",
        "Define database",
        "What is cloud computing?",
        "What is NLP?"
    ],

    "label": [

        # Labels
        "Ambiguous",
        "Ambiguous",
        "Ambiguous",
        "Ambiguous",
        "Ambiguous",
        "Ambiguous",
        "Ambiguous",
